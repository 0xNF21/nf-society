# NF Society — environment variables template
#
# Copy this file to `.env.local` and fill in the values for your own
# deployment. `.env.local` is git-ignored and must NEVER be committed.
#
# Values left empty below are required; blanks must be filled before the
# app can run. Values with a default are safe to leave as-is.

# --- DATABASE ----------------------------------------------------------
# Postgres connection string. Local dev can use `postgres://localhost/...`.
# Vercel deploys use Neon via the dashboard's Environment Variables.
DATABASE_URL=

# --- APP ---------------------------------------------------------------
# Public URL the app is served from (used for server-to-self fetches and
# redirect URLs). Must match the dev server port when working locally.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- CIRCLES PROTOCOL --------------------------------------------------
# RPC endpoint for the Circles stack. Safe default.
NEXT_PUBLIC_CIRCLES_RPC_URL=https://rpc.aboutcircles.com/

# Address shown as the recipient of the first payment demo. Can be any
# address you control; used only as a UI default.
NEXT_PUBLIC_DEFAULT_RECIPIENT_ADDRESS=

# --- GNOSIS SAFE + PAYOUTS (server-only) -------------------------------
# Bot wallet private key. SIGNS every payout through the Roles Modifier.
# Never share this value. Rotate if leaked.
BOT_PRIVATE_KEY=

# Gnosis Safe that holds the DAO funds. The Safe below is NF Society's;
# replace with your own Safe address for a different deployment.
SAFE_ADDRESS=0x960A0784640fD6581D221A56df1c60b65b5ebB6f

# Zodiac Roles Modifier contract that gates what the bot can execute on
# behalf of the Safe.
ROLES_MODIFIER_ADDRESS=

# bytes32 identifier of the role the bot uses (see `src/lib/payout.ts`
# for details). Accepts a 0x-prefixed hex string or a decimal role ID.
# Do not leave blank in production — the app will throw on startup.
ROLE_KEY=

# Maximum payout amount (in CRC) that `executePayout()` accepts. Acts as
# a safety cap in case a bug computes an absurd amount.
MAX_PAYOUT_CRC=1000

# Threshold above which the daily jackpot triggers.
JACKPOT_THRESHOLD_CRC=1000

# Pseudo-address used internally to track DAO treasury commissions in the
# wallet ledger. This is not a real wallet — it's a reserved sentinel.
DAO_TREASURY_ADDRESS=0x000000000000000000000000000000000000da00

# --- ADMIN & CRON (server-only) ----------------------------------------
# Shared secret that protects /api/admin/* routes. Pass it as the
# `x-admin-password` header. Rotate if leaked.
ADMIN_PASSWORD=

# Shared secret for the /api/cron/payouts-monitor endpoint. Used by both
# the Vercel cron and the GitHub Actions backup workflow.
CRON_SECRET=

# --- TELEGRAM BOT (optional) -------------------------------------------
# Bot token from @BotFather. Leave empty to disable Telegram integration.
TELEGRAM_BOT_TOKEN=

# Chat ID of the admin / support forum group.
TELEGRAM_ADMIN_CHAT_ID=

# Forum topic IDs inside the admin chat (grammy routes messages to each
# topic based on the user's category choice).
TELEGRAM_TOPIC_BUG=
TELEGRAM_TOPIC_QUESTION=
TELEGRAM_TOPIC_SUGGESTION=
TELEGRAM_TOPIC_OTHER=

# Bot username displayed in the "Contact support" UI (without the @).
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# --- RATE LIMIT (Upstash Redis, optional in dev) -----------------------
# Required in production — falls back to in-memory in dev if unset. The
# in-memory fallback is per-process and doesn't survive cold starts, so
# rate limits would be effectively multiplied by the number of live
# Vercel instances. Set both to get real protection.
# Provision at https://upstash.com/ (Redis, Regional, TLS on).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
